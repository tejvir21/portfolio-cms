{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "esModuleInterop": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "moduleResolution": "node",

    "ignoreDeprecations": "6.0",

    "resolveJsonModule": true,

    "typeRoots": ["./node_modules/@types", "./src/types"]
  },

  "include": ["src"]
}
